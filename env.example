# ─────────────────────────────────────────────
# Fuel Cell Patent Monitor Agent — Environment Variables
# Copy to .env and fill in your keys
# ─────────────────────────────────────────────

ANTHROPIC_API_KEY=your_anthropic_key_here
GITHUB_TOKEN=ghp_your_token_here
SERPAPI_KEY=your_serpapi_key_here
EPO_KEY=your_epo_key_here
EPO_SECRET=your_epo_secret_here

# ── Fuel Cell Monitoring Config ──────────────

# Key competitors in the PEM fuel cell space
COMPETITORS=advent-technologies,ballard-power-systems,toyota,plug-power,johnson-matthey,basf,gore,sgl-carbon,greenerity

# Keywords covering LT-PEM and HT-PEM technology areas
KEYWORDS=PEM fuel cell,proton exchange membrane,HT-PEM,LT-PEM,polybenzimidazole,MEA membrane electrode,phosphoric acid doping,Nafion membrane,GDL gas diffusion layer,bipolar plate,platinum catalyst,fuel cell degradation,catalyst layer,ionomer,PFSA

# Your technology description — used by Claude for conflict detection
YOUR_TECHNOLOGY=Low-temperature and high-temperature PEM fuel cell stack and MEA development, including PBI-based HT-PEM membranes operating at 120-200C and Nafion-based LT-PEM systems with ultra-low platinum catalyst layers
